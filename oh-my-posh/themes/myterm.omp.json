{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "console_title_template": "{{ .UserName }}@{{ .HostName }} {{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#E06C75",
          "template": "<#ffffff,transparent>\u256d\u2500</> "
        },
        {
          "type": "os",
          "style": "diamond",
          "foreground": "#fff",
          "background": "#003543",
          "template": "{{ if .WSL }}WSL at {{ end }}{{.Icon}}",
          "powerline_symbol": "\ue0b0",
          "options": {
            "windows": "\uf871"
          }
        },
        {
          "type": "session",
          "style": "powerline",
          "foreground": "#d2ff5e",
          "background": "#0087D8",
          "template": "{{ if .SSHSession }}\uf817 {{ end }}{{ .UserName }} ",
          "powerline_symbol": "\ue0b0",
          "options": {
            "display_host": false
          }
        },
        {
          "type": "path",
          "style": "powerline",
          "foreground": "#003544",
          "background": "#91ddff",
          "template": " \ue5ff {{ .Path }} ",
          "powerline_symbol": "\ue0b0",
          "options": {
            "folder_separator_icon": "/",
            "style": "full"
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "foreground": "p:text-light",
          "background": "p:git-bg",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#ff9248{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#f26d50{{ end }}",
            "{{ if gt .Ahead 0 }}#f17c37{{ end }}",
            "{{ if gt .Behind 0 }}#89d1dc{{ end }}"
          ],
          "template": " {{ .HEAD }} {{ .BranchStatus }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Staging.Changed) (.Working.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0}}\uf692 {{ .StashCount }}{{ end }}{{ if gt .WorktreeCount 0}} \uf1bb {{ .WorktreeCount }}{{ end }} ",
          "powerline_symbol": "\ue0b0",
          "options": {
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true
          }
        },
        {
          "type": "az",
          "style": "powerline",
          "foreground": "p:text-light",
          "background": "p:azure-bg",
          "template": " \uebd8 {{ .EnvironmentName }} ",
          "powerline_symbol": "\ue0b0",
          "cache": {
            "duration": "1h",
            "strategy": "session"
          }
        },
        {
          "type": "exit",
          "style": "powerline",
          "foreground": "#242424",
          "background": "#33DD2D",
          "background_templates": [
            "{{ if gt .Code 0 }}#f1184c{{ end }}"
          ],
          "template": " \ufc8d{{ if gt .Code 0 }}\uf00d{{ else }}\uf42e{{ end }} ",
          "powerline_symbol": "\ue0b0",
          "options": {
            "always_enabled": true
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#0087D8",
          "template": "<#FFF>\u2570\u2500</> "
        },
        {
          "type": "root",
          "style": "plain",
          "foreground": "#FFD700",
          "template": "\uf0e7 ",
          "options": {
            "root_icon": "\u26a1"
          }
        },
        {
          "type": "python",
          "style": "powerline",
          "foreground": "#100e23",
          "background": "#906cff",
          "template": " \ue235 {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }} ",
          "powerline_symbol": "\ue0b0"
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "#0087D8",
          "template": "\u276f "
        }
      ]
    }
  ],
  "palette": {
    "text-light": "#000000",
    "text-dark": "#ffffff",
    "azure-bg": "#0078d4",
    "dotnet-bg": "#512bd4",
    "git-bg": "#33DD2D",
    "git-modified-bg": "#ffca00",
    "azfunc-bg": "#ffd800",
    "docker-bg": "#0db7ed",
    "exectime-bg": "#8a3ffc",
    "prompt-ok": "#33DD2D",
    "prompt-error": "#e81123"
  }
}
