{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",

  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [

        {
          "type": "text",
          "style": "plain",
          "foreground": "#E06C75",
          "template": "<#ffffff,transparent>\u256d\u2500</> "
        },

        {
          "type": "os",
          "style": "diamond",
          "foreground": "#fff",
          "background": "#003543",
          "template": "{{ if .WSL }}WSL {{ end }}{{ .Icon }} ",
          "powerline_symbol": "\ue0b0",
          "options": {
            "ubuntu": "\uf31b",
            "debian": "\uf306",
            "arch": "\uf303",
            "linux": "\uf17c",
            "windows": "\uf17a",
            "wsl": "\ue712"
          }
        },

        {
          "type": "session",
          "style": "powerline",
          "foreground": "#d2ff5e",
          "background": "#0087D8",
          "template": "{{ if .SSHSession }}\uf120 {{ end }}{{ .UserName }} ",
          "powerline_symbol": "\ue0b0",
          "options": {
            "display_host": false
          }
        },

        {
          "type": "path",
          "style": "powerline",
          "foreground": "#003544",
          "background": "#91ddff",
          "template": " \ue5ff {{ .Path }} ",
          "powerline_symbol": "\ue0b0",
          "options": {
            "folder_separator_icon": "/",
            "style": "full"
          }
        },

        {
          "type": "git",
          "style": "powerline",
          "foreground": "#193549",
          "background": "#d2ff5e",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#ff9248{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#f26d50{{ end }}",
            "{{ if gt .Ahead 0 }}#f17c37{{ end }}",
            "{{ if gt .Behind 0 }}#89d1dc{{ end }}"
          ],
          "template": " \ue725 {{ .HEAD }} {{ if .Behind }}\u2193{{ .Behind }} behind{{ end }}{{ if .Ahead }} \u2191{{ .Ahead }} ahead{{ end }}{{ if .Staging.Changed }} staged:{{ .Staging.Changed }}{{ end }}{{ if .Working.Changed }} modified:{{ .Working.Changed }}{{ end }}{{ if .StashCount }} \uf0c7 {{ .StashCount }}{{ end }} {{ if .Working.Changed }}\u2718{{ else }}\u2714{{ end }} ",
          "powerline_symbol": "\ue0b0",
          "options": {
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": false,
            "branch_icon": ""
          }
        },

        {
          "type": "az",
          "style": "powerline",
          "foreground": "p:text-light",
          "background": "p:azure-bg",
          "background_templates": [
            "{{ if contains \" Production\" .Name }}#f1184c{{ end }}"
          ],
          "template": "{{ if .EnvironmentName }} \uebd8 {{ .Name }} {{ end }}",
          "powerline_symbol": "\ue0b0"
        },

        {
          "type": "status",
          "style": "powerline",
          "foreground": "#242424",
          "background": "#33DD2D",
          "background_templates": [
            "{{ if gt .Code 0 }}#f1184c{{ end }}"
          ],
          "template": " {{ if gt .Code 0 }}\uf00d{{ else }}\uf42e{{ end }} ",
          "powerline_symbol": "\ue0b0",
          "options": {
            "always_enabled": false
          }
        }
      ]
    },

    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [

        {
          "type": "text",
          "style": "plain",
          "foreground": "#0087D8",
          "template": "<#FFF>\u2570\u2500</> "
        },

        {
          "type": "root",
          "style": "plain",
          "foreground": "#FFD700",
          "template": "\uf0e7 "
        },

        {
          "type": "python",
          "style": "powerline",
          "foreground": "#100e23",
          "background": "#906cff",
          "template": " \ue235 {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }} ",
          "powerline_symbol": "\ue0b0"
        },

        {
          "type": "text",
          "style": "plain",
          "foreground": "#0087D8",
          "template": "\u276f "
        }
      ]
    }
  ],

  "palette": {
    "text-light": "#000000",
    "text-dark": "#ffffff",
    "azure-bg": "#0078d4",
    "git-bg": "#33DD2D"
  }
}
